                            }
                        }
                    },
                    "description": "player metrics",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "summary": "Player-side metrics ingestion",
                "tags": [
                    "internal"
                ]
            }
        },
        "/api/session/{id}/network": {
            "get": {
                "description": "One-shot snapshot of the per-session in-memory request log (HAR-shaped). Bounded; older entries fall off as new ones arrive.",
                "parameters": [
                    {
                        "description": "session_id",
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "items": {
                                        "$ref": "#/components/schemas/main.NetworkLogEntry"
                                    },
                                    "type": "array"
                                }
                            }
                        },
                        "description": "OK"
                    }
                },
                "summary": "Get one session's network ring buffer",
                "tags": [
                    "network"
                ]
            }
        },
        "/api/session/{id}/update": {
            "post": {
                "deprecated": true,
                "parameters": [
                    {
                        "description": "session_id",
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "text/plain": {
                            "schema": {
                                "title": "body",
                                "type": "object"
                            }
                        }
                    },
                    "description": "settings",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "summary": "Legacy session-update POST (use PATCH instead)",
                "tags": [
                    "internal"
                ]
            }
        },
        "/api/sessions": {
            "get": {
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "items": {
                                        "type": "object"
                                    },
                                    "type": "array"
                                }
                            }
                        },
                        "description": "Each item is a normalized session record (~80 fields). Subset returned to the dashboard; harness-cli reads the full record from /api/session/{id}."
                    }
                },
                "summary": "List active sessions",
                "tags": [
                    "sessions"
                ]
            }
        },
        "/api/sessions/stream": {
            "get": {
                "description": "Long-lived `text/event-stream` connection. Server emits one `data:` frame per session-record change (debounced ~250ms). Optional `player_id` query param filters to one player.\n\nEach `data:` frame is a JSON-encoded `SessionStreamFrame` (see schemas).\nHeartbeat: comment line `: ping` every ~15s. Reconnect on disconnect; the proxy does not replay missed frames.",
                "parameters": [
                    {
                        "description": "filter frames to one player_id",
                        "in": "query",
                        "name": "player_id",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "text/event-stream": {
                                "schema": {
                                    "$ref": "#/components/schemas/main.SessionStreamFrame"
                                }
                            }
                        },
                        "description": "JSON payload of one SSE data frame"
                    }
                },
                "summary": "Stream session-state diffs (SSE)",
                "tags": [
                    "streams"
                ]
            }
        },
        "/api/version": {
            "get": {
                "responses": {
                    "200": {
                        "content": {
